{
  "name": "dta-final",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "redis:start": "docker run -d --name dta-redis -p 6379:6379 redis:7-alpine",
    "redis:stop": "docker stop dta-redis && docker rm dta-redis",
    "dev:all": "npm run redis:start && npm run dev"
  },
  "dependencies": {
    "@asyncapi/react-component": "^3.1.0",
    "@types/swagger-ui-react": "^5.18.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bullmq": "^5.28.2",
    "d3": "^7.9.0",
    "ioredis": "^5.6.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "redis": "^5.12.1",
    "remark-gfm": "^4.0.1",
    "swagger-ui-react": "^5.32.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.1.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "happy-dom": "^20.9.0",
    "lightningcss": "^1.32.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^6.2.6",
    "vitest": "^3.0.0"
  }
}
